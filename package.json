{
  "name": "countdown-prank",
  "version": "1.0.0",
  "description": "Horror Countdown Prank App - Educational Purpose",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.prank.countdown",
    "productName": "SystemUpdate",
    "files": [
      "index.html",
      "style.css",
      "script.js",
      "main.js",
      "preload.js",
      "yamete-kudasai.mp3"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
